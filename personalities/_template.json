{
  "id": "your_personality_id",
  "name": "Display Name Here",
  "description": "One-line summary shown in selection menu.",

  "starting_dopamine": 50,
  "decay_per_turn": -5,
  "praise_bonus": 35,
  "max_dopamine": 100,
